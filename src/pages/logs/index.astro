---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import { getCollection } from 'astro:content';

const events = await getCollection('events');

const eventCards = events
  .flatMap((entry) =>
    [...entry.data.dates]
      .sort((a, b) => b.getTime() - a.getTime())
      .map((date) => ({
        eventName: entry.data.eventName,
        date,
        location: entry.data.location,
      })),
  )
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout
  title="ログ"
  description="イベント参加記録など、軽量コンテンツの一覧です。"
  ogImage="/img/logs/og.png"
>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold text-text">ログ</h1>
      <span class="text-sm text-text-muted">{eventCards.length} 件</span>
    </div>

    {eventCards.length === 0 ? (
      <p class="text-text-muted">イベントがまだありません。</p>
    ) : (
      <ul class="flex flex-col gap-4 list-none p-0 m-0">
        {eventCards.map((card) => (
          <li>
            <EventCard
              eventName={card.eventName}
              date={card.date}
              location={card.location}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
