---
import OGImageCard from '../../components/OGImageCard.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const slides = await getCollection('slides', ({ data }) => !data.draft);
const stories = await getCollection('stories', ({ data }) => !data.draft);
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <title>OG Image Generation</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body class="flex flex-col gap-10 p-10 bg-[#ccc]">
  <div id="og-home" class="shrink-0 shadow-xl w-[1200px] h-[630px]">
    <OGImageCard
      title="いそしぎ忘備録"
      description="検証結果や試行記録を「物語として完成させ」、小さな成果として蓄積していくアウトプット共有サイト。"
      publishedAt={new Date('2026-01-01')}
      tags={[]}
    />
  </div>

  <div id="og-pages" class="shrink-0 shadow-xl w-[1200px] h-[630px]">
    <OGImageCard
      title="すべての記録"
      description="技術記事、スライド、ストーリーなど、すべてのコンテンツを時系列で一覧表示しています。"
      publishedAt={new Date('2026-01-01')}
      tags={[]}
    />
  </div>

  <div id="og-logs" class="shrink-0 shadow-xl w-[1200px] h-[630px]">
    <OGImageCard
      title="ログ"
      description="イベント参加記録など、軽量コンテンツの一覧です。"
      publishedAt={new Date('2026-01-01')}
      tags={[]}
    />
  </div>

  {articles.map((entry) => (
    <div id={`og-article-${entry.id}`} class="shrink-0 shadow-xl w-[1200px] h-[630px]">
      <OGImageCard
        type="article"
        title={entry.data.title}
        description={entry.data.description}
        publishedAt={entry.data.publishedAt}
        updatedAt={entry.data.updatedAt}
        tags={entry.data.tags}
      />
    </div>
  ))}

  {slides.map((entry) => (
    <div id={`og-slide-${entry.id}`} class="shrink-0 shadow-xl w-[1200px] h-[630px]">
      <OGImageCard
        type="slide"
        title={entry.data.title}
        description={entry.data.description}
        publishedAt={entry.data.publishedAt}
        updatedAt={entry.data.updatedAt}
        tags={entry.data.tags}
      />
    </div>
  ))}

  {stories.map((entry) => (
    <div id={`og-story-${entry.id}`} class="shrink-0 shadow-xl w-[1200px] h-[630px]">
      <OGImageCard
        type="story"
        title={entry.data.title}
        description={entry.data.description}
        publishedAt={entry.data.publishedAt}
        updatedAt={entry.data.updatedAt}
        tags={entry.data.tags}
      />
    </div>
  ))}
</body>
</html>
