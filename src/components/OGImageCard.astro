---
export interface Props {
  type?: 'article' | 'event' | 'slide' | 'story';
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags?: string[];
}

const { type, title, description, publishedAt, updatedAt, tags } = Astro.props;

const typeLabels: Record<string, string> = {
  article: 'Article',
  event: 'Event',
  slide: 'Slide',
  story: 'Story',
};

const formatDate = (d: Date) => {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
};
---

<div
  class="og-card flex flex-col justify-between bg-surface text-text"
  style="width: 1200px; height: 630px; padding: 48px; border-left: 16px solid var(--color-accent); font-family: 'Noto Sans JP', sans-serif; box-sizing: border-box;"
>
  <div>
    <div class="flex items-center gap-4 mb-8">
      {type && (
        <span
          class="inline-block px-4 py-1 text-xl font-semibold bg-accent-light text-accent rounded-sm"
          style="border-radius: 4px;"
        >
          {typeLabels[type]}
        </span>
      )}
      <time class="text-lg text-text-muted" datetime={publishedAt.toISOString()}>
        {formatDate(publishedAt)}
        {updatedAt && updatedAt.getTime() !== publishedAt.getTime() && (
          <span>（更新: {formatDate(updatedAt)}）</span>
        )}
      </time>
    </div>

    <h1
      class="font-bold text-text leading-tight mb-6"
      style="font-size: 56px; max-height: 160px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;"
    >
      {title}
    </h1>

    <p
      class="text-text-muted leading-relaxed"
      style="font-size: 28px; max-height: 120px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;"
    >
      {description}
    </p>
  </div>

  <div class="flex items-end justify-between mt-6">
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-3">
        {tags.map((tag) => (
          <span
            class="inline-block px-4 py-1.5 bg-accent-light text-accent text-lg font-medium border border-accent-light"
            style="border-radius: 4px;"
          >
            {tag}
          </span>
        ))}
      </div>
    )}
    <div class="text-xl font-bold text-text-muted ml-auto shrink-0">
      isoshigi.dev
    </div>
  </div>
</div>
