---
import { typeLabels } from '../lib/typeLabels.ts';
import { formatDate } from '../lib/formatDate.ts';

export interface Props {
  type?: 'article' | 'event' | 'slide' | 'story';
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags?: string[];
}

const { type, title, description, publishedAt, updatedAt, tags } = Astro.props;
---

<div
  class="og-card flex flex-col justify-between bg-surface text-text w-[1200px] h-[630px] p-[48px] border-l-[16px] border-l-accent box-border font-['Noto_Sans_JP',sans-serif]"
>
  <div>
    <div class="flex items-center gap-4 mb-8">
      {type && (
        <span
          class="inline-block px-4 py-1 text-xl font-semibold bg-accent-light text-accent rounded"
        >
          {typeLabels[type]}
        </span>
      )}
      <time class="text-lg text-text-muted" datetime={publishedAt.toISOString()}>
        {formatDate(publishedAt)}
        {updatedAt && updatedAt.getTime() !== publishedAt.getTime() && (
          <span>（更新: {formatDate(updatedAt)}）</span>
        )}
      </time>
    </div>

    <h1
      class="font-bold text-text leading-tight mb-6 text-[56px] max-h-[160px] line-clamp-2"
    >
      {title}
    </h1>

    <p
      class="text-text-muted leading-relaxed text-[28px] max-h-[120px] line-clamp-3"
    >
      {description}
    </p>
  </div>

  <div class="flex items-end justify-between mt-6">
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-3">
        {tags.map((tag) => (
          <span class="badge px-4 py-1.5 text-lg font-medium">
            {tag}
          </span>
        ))}
      </div>
    )}
    <div class="text-xl font-bold text-text-muted ml-auto shrink-0">
      isoshigi.dev
    </div>
  </div>
</div>
