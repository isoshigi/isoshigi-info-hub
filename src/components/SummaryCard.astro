---
import { typeLabels } from '../lib/typeLabels.ts';
import { formatDate } from '../lib/formatDate.ts';

export interface Props {
  type: 'article' | 'event' | 'slide' | 'story';
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags?: string[];
  coverImage?: string;
  href?: string;
}

const { type, title, description, publishedAt, updatedAt, tags, coverImage, href } = Astro.props;

const Element = href ? 'a' : 'div';
---

<Element class:list={['card', href ? 'interactive-card' : '']} href={href}>
  {coverImage && (
    <div class="overflow-hidden border-b border-border">
      <img src={coverImage} alt="" class="w-full h-32 object-cover" loading="lazy" />
    </div>
  )}
  <div class="flex flex-col gap-2 min-w-0">
    <div class="flex items-center gap-2 flex-wrap">
      <span class="badge">{typeLabels[type]}</span>
      <time class="text-xs text-text-muted" datetime={publishedAt.toISOString()}>
        {formatDate(publishedAt)}
        {updatedAt && updatedAt.getTime() !== publishedAt.getTime() && (
          <span>（更新: {formatDate(updatedAt)}）</span>
        )}
      </time>
    </div>
    <h3 class="text-base font-bold text-text truncate">{title}</h3>
    <p class="text-sm text-text-muted line-clamp-2">{description}</p>
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-1">
        {tags.map((tag) => (
          <span class="badge">{tag}</span>
        ))}
      </div>
    )}
  </div>
</Element>
