---
export interface Props {
  url: string;
  title: string;
  description?: string;
  hashtag?: string;
  mention?: string;
}

const { url, title, description = '', hashtag = '', mention = '' } = Astro.props;

let text = title;
if (description) text += '\n' + description;
if (mention) text += '\n@' + mention;

const shareUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(text)}${hashtag ? '&hashtags=' + encodeURIComponent(hashtag) : ''}`;
---

<a
  href={shareUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center gap-1.5 text-sm"
>
  Xでシェア
</a>
