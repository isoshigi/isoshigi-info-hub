---
export interface Props {
  href?: string;
  label?: string;
}

const { href = '/pages', label = 'すべての記録に戻る' } = Astro.props;
---

<footer class="pt-6 border-t border-border">
  <a href={href} class="text-sm font-medium text-text-muted hover:text-link-hover transition-colors">← {label}</a>
</footer>
