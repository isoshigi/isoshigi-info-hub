---
import '../styles/global.css';
import ShareButton from '../components/ShareButton.astro';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description, ogImage = '/img/og.png', ogType = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const ogImageURL = new URL(ogImage, Astro.site || Astro.url.origin);
const fullTitle = title === 'いそしぎ忘備録' ? title : `${title} | いそしぎ忘備録`;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>

  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="いそしぎ忘備録" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
</head>
<body class="min-h-screen flex flex-col bg-bg">
  <header class="bg-header border-b-4 border-accent">
    <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-header-fg hover:text-header-fg/80 transition-colors">
        いそしぎ忘備録
      </a>
      <nav class="flex items-center gap-4">
        <a href="/" class="text-sm font-medium text-header-fg/80 hover:text-header-fg transition-colors">Home</a>
        <a href="/pages" class="text-sm font-medium text-header-fg/80 hover:text-header-fg transition-colors">すべての記録</a>
        <a href="/logs" class="text-sm font-medium text-header-fg/80 hover:text-header-fg transition-colors">ログ</a>
      </nav>
    </div>
  </header>

  <div class="flex-1 max-w-5xl mx-auto w-full px-4 py-8 flex flex-col lg:flex-row gap-8">
    <main class="flex-1 min-w-0">
      <slot />
    </main>

    <aside class="w-full lg:w-64 shrink-0 space-y-4">
      <div class="card">
        <h3 class="text-sm font-bold text-text mb-2">このページをシェア</h3>
        <ShareButton
          url={canonicalURL.toString()}
          title={title}
          description={description}
        />
      </div>
      <div class="card">
        <h3 class="text-sm font-bold text-text mb-2">プロフィール</h3>
        <p class="text-sm text-text-muted mb-3">技術的なアウトプットを小さく継続していくことを目指しています。</p>
        <div class="flex flex-col gap-1.5">
          <a href="https://x.com/isoshigicchi" target="_blank" rel="noopener noreferrer" class="text-sm w-fit">X @isoshigicchi</a>
          <a href="https://github.com/isoshigi" target="_blank" rel="noopener noreferrer" class="text-sm w-fit">GitHub isoshigi</a>
        </div>
      </div>
    </aside>
  </div>

  <footer class="bg-header border-t-4 border-accent mt-auto">
    <div class="max-w-5xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-sm text-header-fg/60">© 2026 いそしぎ</p>
      <div class="flex items-center gap-4">
        <a href="https://x.com/isoshigicchi" target="_blank" rel="noopener noreferrer" class="text-sm text-header-fg/80 hover:text-header-fg transition-colors">X</a>
        <a href="https://github.com/isoshigi" target="_blank" rel="noopener noreferrer" class="text-sm text-header-fg/80 hover:text-header-fg transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
</body>
</html>
